{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "SwingMusic",
  "version": "1.0.0",
  "identifier": "com.swingmusic.desktop",
  "build": {
    "beforeBuildCommand": "cd ../swingmusic-webclient && npm run build",
    "beforeDevCommand": "cd ../swingmusic-webclient && npm run dev",
    "frontendDist": "../swingmusic-webclient/dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "SwingMusic",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": false,
        "transparent": false,
        "alwaysOnTop": false,
        "skipTaskbar": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Music",
    "shortDescription": "Advanced music player with Universal Source integration",
    "longDescription": "SwingMusic is a powerful desktop music player with advanced features including Universal Source URL downloading, intelligent recommendations, and comprehensive audio management.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    },
    "macOS": {
      "entitlements": null,
      "exceptionDomain": "",
      "frameworks": [],
      "providerShortName": null,
      "signingIdentity": null
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
